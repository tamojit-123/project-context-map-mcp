    "src",
    "scripts",
    ".claude/skills/project-context-map/SKILL.md",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "engines": {
    "node": ">=20"
  }
}
